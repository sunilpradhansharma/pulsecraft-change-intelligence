<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>{{ subject }}</title>
  <style>
    body { font-family: Arial, sans-serif; color: #333; max-width: 600px; margin: auto; }
    h2 { color: #1a1a2e; }
    .action { margin: 4px 0; }
    .footer { margin-top: 32px; font-size: 0.85em; color: #888; border-top: 1px solid #ddd; padding-top: 8px; }
  </style>
</head>
<body>
  <h2>{{ subject }}</h2>
  <p>Dear {{ recipient_name }},</p>
  <p>{{ body }}</p>
  {% if recommended_actions %}
  <h3>Recommended Actions</h3>
  <ul>
    {% for action in recommended_actions %}
    <li class="action"><strong>{{ action.owner }}</strong>: {{ action.action }}{% if action.by_when %} <em>(by {{ action.by_when }})</em>{% endif %}</li>
    {% endfor %}
  </ul>
  {% endif %}
  <div class="footer">This notification was generated by PulseCraft. Please do not reply to this message.</div>
</body>
</html>
